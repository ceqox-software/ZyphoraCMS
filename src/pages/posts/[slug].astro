---
/**
 * Single-post route. Looks up the post by slug (published only — drafts are
 * never publicly visible) and renders via the active theme's `post.eta`.
 *
 * 404s render through the theme too so the look stays consistent on miss.
 */
import { db, schema } from '../../db/client.ts';
import { eq, and } from 'drizzle-orm';
import { renderTheme } from '../../lib/themes/render.ts';

const { slug } = Astro.params;
if (!slug) {
  return await renderTheme({ template: 'notFound', pathname: Astro.url.pathname, status: 404 });
}

const row = await db
  .select({
    slug: schema.posts.slug,
    title: schema.posts.title,
    excerpt: schema.posts.excerpt,
    contentHtml: schema.posts.contentHtml,
    publishedAt: schema.posts.publishedAt,
    authorName: schema.users.displayName,
  })
  .from(schema.posts)
  .leftJoin(schema.users, eq(schema.users.id, schema.posts.authorId))
  .where(and(eq(schema.posts.slug, slug), eq(schema.posts.status, 'published')))
  .get();

if (!row) {
  return await renderTheme({ template: 'notFound', pathname: Astro.url.pathname, status: 404 });
}

return await renderTheme({
  template: 'post',
  pathname: Astro.url.pathname,
  post: row,
});
---