---
/**
 * Edit-post form. Mirrors `new.astro`'s validation+restore pattern; on save
 * we PRG-redirect with `?saved=1` so the success banner survives a refresh
 * and the POST doesn't replay if the user hits back.
 *
 * Authorization: `canEditPost` enforces the per-role rule (admins/editors
 * can edit anyone's post; authors only their own). Without this gate, the
 * routing layer alone would let any logged-in author edit any post.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import TiptapEditor from '../../../components/TiptapEditor.tsx';
import { db, schema } from '../../../db/client.ts';
import { eq } from 'drizzle-orm';
import { postFormSchema, updatePost } from '../../../lib/posts.ts';
import { canEditPost } from '../../../lib/auth.ts';

// Resolve the post and run the role check before doing anything else.
// Missing id / missing post both bounce back to the list silently — we
// don't want to leak whether a post exists to a user who couldn't edit it.
const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/posts');

const post = await db.select().from(schema.posts).where(eq(schema.posts.id, id)).get();
if (!post) return Astro.redirect('/admin/posts');

if (!canEditPost(Astro.locals.user, post)) {
  return new Response('Forbidden', { status: 403 });
}

let error: string | null = null;
let success: string | null = null;
let values = {
  title: post.title,
  slug: post.slug,
  excerpt: post.excerpt ?? '',
  contentHtml: post.contentHtml,
  status: post.status,
  category: post.category,
  commentsEnabled: post.commentsEnabled,
};

if (Astro.url.searchParams.get('created') === '1') success = 'Post created.';

if (Astro.request.method === 'POST') {
  // Same validation flow as the new-post page; on error, restore the form
  // with the user's typed values so they don't lose work.
  const form = await Astro.request.formData();
  // Unchecked checkboxes are omitted from form data entirely — presence
  // alone means checked.
  const commentsEnabled = form.get('commentsEnabled') !== null;
  const parsed = postFormSchema.safeParse({
    title: form.get('title') ?? '',
    slug: form.get('slug') ?? '',
    excerpt: form.get('excerpt') ?? '',
    contentHtml: form.get('contentHtml') ?? '',
    status: form.get('status') ?? 'draft',
    category: form.get('category') ?? 'news',
    commentsEnabled,
  });

  if (!parsed.success) {
    error = parsed.error.issues[0]?.message ?? 'Invalid input';
    const rawCategory = String(form.get('category') ?? 'news');
    values = {
      title: String(form.get('title') ?? ''),
      slug: String(form.get('slug') ?? ''),
      excerpt: String(form.get('excerpt') ?? ''),
      contentHtml: String(form.get('contentHtml') ?? ''),
      status: (form.get('status') === 'published' ? 'published' : 'draft'),
      category: (['news', 'travel', 'gadgets', 'reviews'].includes(rawCategory) ? rawCategory : 'news') as 'news' | 'travel' | 'gadgets' | 'reviews',
      commentsEnabled,
    };
  } else {
    // Pass the previous status + publishedAt so updatePost can preserve the
    // original publish date when toggling between published states.
    await updatePost(id, parsed.data, post.status, post.publishedAt);
    return Astro.redirect(`/admin/posts/${id}?saved=1`);
  }
}

if (Astro.url.searchParams.get('saved') === '1') success = 'Post saved.';
---
<AdminLayout title={`Edit · ${post.title}`}>
  <div class="toolbar">
    <h1 style="margin:0">Edit post</h1>
    <div class="actions">
      {post.status === 'published' && <a href={`/posts/${post.slug}`} target="_blank" class="btn secondary">View live</a>}
      <a href="/admin/posts" class="btn secondary">← Back</a>
    </div>
  </div>

  {success && <div class="alert success">{success}</div>}
  {error && <div class="alert error">{error}</div>}

  <form method="POST">
    <div class="card" style="margin-bottom:16px">
      <div class="field">
        <label for="title">Title</label>
        <input class="input" id="title" name="title" required value={values.title} />
      </div>
      <div class="field">
        <label for="slug">Slug</label>
        <input class="input" id="slug" name="slug" value={values.slug} />
      </div>
      <div class="field">
        <label for="excerpt">Excerpt</label>
        <textarea class="textarea" id="excerpt" name="excerpt" rows="2">{values.excerpt}</textarea>
      </div>
      <div class="field">
        <label>Content</label>
        <TiptapEditor name="contentHtml" initialHtml={values.contentHtml} client:only="react" />
      </div>
      <div class="field">
        <label for="status">Status</label>
        <select class="select" id="status" name="status">
          <option value="draft" selected={values.status === 'draft'}>Draft</option>
          <option value="published" selected={values.status === 'published'}>Published</option>
        </select>
      </div>
      <div class="field">
        <label for="category">Category</label>
        <select class="select" id="category" name="category">
          <option value="news" selected={values.category === 'news'}>News</option>
          <option value="travel" selected={values.category === 'travel'}>Travel</option>
          <option value="gadgets" selected={values.category === 'gadgets'}>Gadgets</option>
          <option value="reviews" selected={values.category === 'reviews'}>Reviews</option>
        </select>
      </div>
      <div class="field">
        <label style="display:inline-flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" name="commentsEnabled" checked={values.commentsEnabled} />
          <span>Allow comments on this post</span>
        </label>
      </div>
    </div>
    <button type="submit" class="btn">Save changes</button>
  </form>
</AdminLayout>